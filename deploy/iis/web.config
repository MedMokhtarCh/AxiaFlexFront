<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS : site pointant vers le dossier Frontend/dist (après npm run build).
  L’API Node.js tourne en local (ex. 127.0.0.1:3001) — service Windows, PM2, NSSM, etc.

  Prérequis IIS :
  - Module URL Rewrite : https://www.iis.net/downloads/microsoft/url-rewrite
  - Application Request Routing (ARR) : activer le proxy (niveau serveur :
    IIS → Application Request Routing Cache → Server Proxy Settings → Enable proxy)

  WebSocket : fonctionnalité « WebSocket Protocol » dans les rôles Windows (WCF / IIS).

  Après édition, adapter le port si votre backend n’écoute pas sur 3001
  (variable PORT dans le .env du backend).
-->
<configuration>
  <system.webServer>
    <webSocket enabled="true" />
    <rewrite>
      <rules>
        <!-- Proxy WebSocket (temps réel POS) -->
        <rule name="Pos WebSocket" stopProcessing="true">
          <match url="^ws(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/ws{R:1}" appendQueryString="true" />
        </rule>
        <!-- Fichiers uploadés -->
        <rule name="Pos Uploads" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/uploads/{R:1}" appendQueryString="true" />
        </rule>
        <!-- Super Admin SaaS (même backend) -->
        <rule name="SaaS API" stopProcessing="true">
          <match url="^saas/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/saas/{R:1}" appendQueryString="true" />
        </rule>
        <!-- API REST -->
        <rule name="Pos API" stopProcessing="true">
          <match url="^pos/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/pos/{R:1}" appendQueryString="true" />
        </rule>
        <!-- Documentation Swagger (optionnel) -->
        <rule name="Pos Docs" stopProcessing="true">
          <match url="^docs(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/docs{R:1}" appendQueryString="true" />
        </rule>
        <!-- SPA React : toutes les autres URLs → index.html -->
        <rule name="Pos SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
